# Supabase: prisma migrate / db push / Render 빌드는 DATABASE_URL 하나만 사용합니다.
# Transaction pooler(6543)만 쓰면 migrate·DDL이 멈추거나 실패할 수 있어, 같은 호스트의 Session(5432) URI를 DATABASE_URL로 두는 것을 권장합니다.
# 비밀번호에 특수문자가 있으면 URL 인코딩이 필요할 수 있습니다.
# DATABASE_URL="postgresql://postgres.xxx:...@....pooler.supabase.com:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/hospital_scheduling"

JWT_SECRET="긴-무작위-문자열으로-변경"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
