# Supabase · Pooler 사용 시:
# - DATABASE_URL: Transaction pooler (6543, ?pgbouncer=true&connection_limit=1 등) — 런타임(Express)
# - DIRECT_URL: 같은 pooler 호스트의 Session 모드 (5432) 또는 Direct db.xxx.supabase.co:5432 — prisma migrate / db push
# 비밀번호 특수문자는 URL 인코딩 필요할 수 있음.
# DATABASE_URL="postgresql://postgres.xxx:...@....pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.xxx:...@....pooler.supabase.com:5432/postgres?sslmode=require"

# 로컬 Postgres만 쓸 때는 두 변수를 동일 URI로 두어도 됩니다.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/hospital_scheduling"
DIRECT_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/hospital_scheduling"

JWT_SECRET="긴-무작위-문자열으로-변경"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
