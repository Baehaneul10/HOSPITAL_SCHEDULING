# 로컬 기본: SQLite (파일은 prisma/dev.db). 별도 설정 없이 서버 실행 가능.
DATABASE_URL="file:./dev.db"

# MariaDB 사용 시: prisma/schema.prisma 의 provider 를 mysql 로 변경한 뒤 아래 형식 사용
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/hospital_scheduling"

JWT_SECRET="긴-무작위-문자열으로-변경"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
